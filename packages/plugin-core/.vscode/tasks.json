// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile-plugin-core",
      "type": "shell",
      "command": "yarn compile",
      "problemMatcher": ["$tsc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "detail": "Compile the extension (tsc) - used by F5 launch configs"
    },
    {
      "label": "watch-plugin-core",
      "type": "shell",
      "command": "yarn watch",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "detail": "Watch mode (run in a separate terminal for fast iteration)"
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": "build",
      "label": "npm: watch (legacy)",
      "detail": "tsc -watch -p ./"
    },
    {
      "type": "npm",
      "script": "watch-web",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$ts-webpack-watch"]
    },
    {
      "label": "gen:config",
      "type": "shell",
      "command": "node out/scripts/genConfig.js",
      "problemMatcher": []
    },
    {
      "label": "sync:tutorial",
      "type": "shell",
      "command": "node ../dendron-cli/lib/bin/dendron-cli.js dev sync_tutorial",
      "problemMatcher": []
    }
  ]
}
