// Launch configurations for developing the Dendron VS Code extension.
// 
// IMPORTANT: These configs assume you have the `packages/plugin-core` folder
// (or dendron-plugin.code-workspace) open as your VS Code workspace root.
//
// Recommended usage:
//   1. File → Open Workspace from File... → dendron-plugin.code-workspace
//   2. In the Debug view (Ctrl+Shift+D), select "Run Dendron Extension (Desktop)"
//   3. Press F5 (or green play button)
//
// This will compile the extension and launch a new Extension Development Host window.
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Dendron Extension (Desktop)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "compile-plugin-core",
      "env": {
        "LOG_LEVEL": "debug",
        "DENDRON_DEV_MODE": "1",
        "DENDRON_PERF": "1"
      },
      "presentation": {
        "group": "dendron",
        "order": 1
      }
    },
    {
      "name": "Run Dendron Extension (Desktop, No Precompile)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "env": {
        "LOG_LEVEL": "debug",
        "DENDRON_DEV_MODE": "1"
      },
      "presentation": {
        "group": "dendron",
        "order": 2
      }
    },
    {
      "name": "Run Dendron Extension (Clean Host - disable all other extensions)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "compile-plugin-core",
      "env": {
        "LOG_LEVEL": "debug",
        "DENDRON_DEV_MODE": "1",
        "DENDRON_PERF": "1"
      },
      "presentation": {
        "group": "dendron",
        "order": 3
      }
    },
    // {
    //   "name": "Run Web Extension in VS Code",
    //   "type": "pwa-extensionHost",
