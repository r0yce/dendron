    //   ],
    //   "preLaunchTask": "npm: watch-web",
    //   "sourceMapPathOverrides": {
    //     "*": "${webRoot}/*"
    //   }
    // },
    {
      "name": "Debug Dendron Extension Tests (Integration)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/src/test/suite-integ/index"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "compile-plugin-core",
      "env": {
        "LOG_LEVEL": "debug"
      },
      "presentation": {
        "group": "dendron-tests",
        "order": 1
      }
    },
    {
      "name": "Debug Current Test File (Jest)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/../node_modules/jest/bin/jest.js",
      "sourceMaps": true,
      "smartStep": true,
      "env": {
        "LOG_LEVEL": "info"
      },
      "args": [
        "--findRelatedTests",
        "--runInBand",
        "${relativeFile}",
        "-u"
      ],
      "outFiles": [
        "${workspaceFolder}/../packages/engine-test-utils/lib/**/*.js"
      ],
      "presentation": {
        "group": "tests",
        "order": 10
      }
    },
    {
      "name": "Attach to Running Extension Host",
      "type": "extensionHost",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ]
    }
  ]
}