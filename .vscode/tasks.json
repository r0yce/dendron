{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "gen:data",
      "problemMatcher": [],
      "label": "generate JSON schema",
      "detail": "node packages/dendron-cli/lib/bin/dendron-cli.js dev generate_json_schema_from_config"
    },
    {
      "label": "test:watch",
      "command": "yarn test ${relativeFile} --watch --bail -u",
      "type": "shell",
      "problemMatcher": [],
      "options": {
        "env": {
          "LOG_LEVEL": "info",
          "LOG_DST": "${workspaceFolder}/engine-test-utils.log"
        }
      }
    },
    {
      "label": "compile:plugin-core",
      "type": "shell",
      "command": "yarn workspace @dendronhq/plugin-core compile",
      "problemMatcher": ["$tsc"],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "compile:watch:plugin-core",
      "type": "shell",
      "command": "yarn workspace @dendronhq/plugin-core watch",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "bootstrap:fast (common packages + plugin)",
      "type": "shell",
      "command": "yarn bootstrap:build:fast",
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}